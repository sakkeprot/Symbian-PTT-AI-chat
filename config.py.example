# =============================================================================
# PoC AI Proxy — Configuration template
# Copy this to config.py and fill in your values.
# config.py is in .gitignore — never commit it with real keys.
# =============================================================================

# ---- Language ----------------------------------------------------------------
# Controls STT language, TTS voice, and AI system prompt.
# Supported: "dutch", "english", "french", "german", "spanish"
LANGUAGE = "dutch"

# ---- Network ----------------------------------------------------------------
MY_IP    = ""   # Public IP of this server — used in SDP offers
PHONE_IP = ""   # IP of the PoC phone (informational only)

LISTEN_PORT   = 5060
ASTERISK_IP   = "127.0.0.1"
ASTERISK_PORT = 5061

RTP_PORT    = 19998
TBCP_PORT   = 19999
SERVER_SSRC = 0x12345678

# ---- API keys ---------------------------------------------------------------
DEEPSEEK_API_KEY = ""   # https://platform.deepseek.com
GROQ_API_KEY     = ""   # https://console.groq.com  (leave blank for local STT only)

# ---- Local paths ------------------------------------------------------------
WHISPER          = "/home/ubuntu/whisper.cpp/build/bin/whisper-cli"
MODEL            = "/home/ubuntu/whisper.cpp/models/ggml-base.bin"
HOLD_MUSIC_FILES = ["/home/ubuntu/beepboop.wav"]

# ---- Logging ----------------------------------------------------------------
LOG_FILE = "/home/ubuntu/sip_proxy.log"

# =============================================================================
# Language profiles — add new languages here
# Format: "key": (whisper_lang_code, edge_tts_voice, system_prompt)
# List available TTS voices with:  edge-tts --list-voices
# =============================================================================
