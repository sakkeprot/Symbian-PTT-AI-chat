# =============================================================================
# PoC AI Proxy — Configuration template
# Copy this to config.py and fill in your values.
# config.py is in .gitignore — never commit it with real keys.
#
# All file paths are relative to the repo root (the folder this file is in),
# so the proxy works wherever you cloned or placed the repo.
# =============================================================================
import os
_HERE = os.path.dirname(os.path.abspath(__file__))

# ---- Language ----------------------------------------------------------------
# Controls STT language, TTS voice, and AI system prompt.
# Supported: "dutch", "english", "french", "german", "spanish"
LANGUAGE = "dutch"

# ---- Network ----------------------------------------------------------------
MY_IP    = ""   # Public IP of this server — used in SDP offers
PHONE_IP = ""   # IP of the PoC phone (informational only)

LISTEN_PORT   = 5060
ASTERISK_IP   = "127.0.0.1"
ASTERISK_PORT = 5061

RTP_PORT    = 19998
TBCP_PORT   = 19999
SERVER_SSRC = 0x12345678

# ---- API keys ---------------------------------------------------------------
# DeepSeek: https://platform.deepseek.com  (top up $1-2 for months of use)
DEEPSEEK_API_KEY = ""
# Groq:     https://console.groq.com       (free tier, used for Whisper STT)
GROQ_API_KEY     = ""

# ---- Paths (relative to repo root — no need to change these) ----------------
# whisper.cpp is cloned into the repo folder by install.sh
WHISPER = os.path.join(_HERE, "whisper.cpp", "build", "bin", "whisper-cli")
MODEL   = os.path.join(_HERE, "whisper.cpp", "models", "ggml-base.bin")

# Hold music played while the AI is thinking — beepboop.wav ships with the repo
HOLD_MUSIC_FILES = [os.path.join(_HERE, "beepboop.wav")]

# Log file written next to the proxy
LOG_FILE = os.path.join(_HERE, "sip_proxy.log")

# =============================================================================
# Language profiles
# Format: "key": (whisper_lang_code, edge_tts_voice, system_prompt)
# Add new languages here.  List available TTS voices:  edge-tts --list-voices
# =============================================================================
